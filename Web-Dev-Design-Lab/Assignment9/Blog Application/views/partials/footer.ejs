    <div class="footer-container">
      <div class="footer-brand">
        <span class="logo-icon">✦</span>
        <span class="logo-text">BlogVerse</span>
      </div>
      <p class="footer-text">&copy; <%= new Date().getFullYear() %> BlogVerse. All rights reserved.</p>
